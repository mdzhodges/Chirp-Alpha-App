# trainer config
NUM_EPOCHS=100
SAMPLE_SIZE=1000000
DATA_PATH=/home/ubuntu/training/data
DATA_FORMAT=parquet

# S3 config - bucket name will be output by terraform as s3_bucket_name
S3_BUCKET=chirp-training-us-east-1
S3_PREFIX=training-results
AWS_REGION=us-east-1

# parallelization workers
MAX_WORKERS=8